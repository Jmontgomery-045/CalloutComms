{
  "name": "callout",
  "version": "0.1.1",
  "description": "Private, peer-to-peer voice and messaging desktop app",
  "author": "Jmontgomery-045",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jmontgomery-045/CalloutComms.git"
  },
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "make-icons": "node scripts/make-icons.mjs",
    "dist": "electron-vite build && electron-builder --win"
  },
  "build": {
    "appId": "com.callout.app",
    "productName": "callout",
    "electronVersion": "29.0.1",
    "icon": "assets/icon.ico",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "assets/icon.ico"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "shortcutName": "callout"
    },
    "mac": {
      "icon": "assets/icon.png",
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": ["AppImage"]
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "libsodium-wrappers": "^0.7.13",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sql.js": "^1.12.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/libsodium-wrappers": "^0.7.13",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "29.0.1",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  }
}
